<% const canSee = (perm) => isServerManager || (typeof userPermissions !== 'undefined' && userPermissions && userPermissions.includes(perm)); %>
<script>window.DASHBOARD_ACTIVE = true;</script>
<aside class="sidebar">
  <a href="/servers" class="brand" style="padding:2px 10px 14px 10px;font-size:14px;">
    <span class="dot"></span> Nexus Systems
  </a>
  <div class="guild-switcher">
    <button class="guild-name" id="guild-switcher-btn" type="button">
      <% if (guild.iconURL && guild.iconURL()) { %>
        <img src="<%= guild.iconURL() %>" alt="" />
      <% } else { %>
        <div class="icon-fallback" style="width:32px;height:32px;border-radius:50%;background:var(--bg-card);display:flex;align-items:center;justify-content:center;font-size:13px;"><%= guild.name.slice(0,2).toUpperCase() %></div>
      <% } %>
      <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= guild.name %></span>
      <% if (typeof vip !== 'undefined' && vip && vip.active) { %><span title="VIP server" style="margin-left:2px;">💎</span><% } %>
      <span class="switcher-chevron">▾</span>
    </button>
    <div class="guild-switcher-menu" id="guild-switcher-menu"></div>
  </div>

  <div class="sidebar-tools">
    <button class="icon-btn" id="palette-trigger-btn" title="Quick jump (Ctrl+K)">⌘K</button>
    <button class="icon-btn" id="theme-toggle-btn" title="Toggle theme">🌙</button>
    <% if (isServerManager || canSee('manage_antiraid') || canSee('manage_config')) { %>
      <button class="icon-btn" id="lockdown-toggle-btn" title="Toggle emergency lockdown">🔓</button>
    <% } %>
  </div>

  <div class="nav-section">General</div>
  <a class="navlink <%= page === 'overview' ? 'active' : '' %>" href="/servers/<%= guildId %>">📊 Overview</a>
  <a class="navlink <%= page === 'analytics' ? 'active' : '' %>" href="/servers/<%= guildId %>/analytics">📈 Analytics</a>
  <% if (canSee('manage_moderation')) { %><a class="navlink <%= page === 'members' ? 'active' : '' %>" href="/servers/<%= guildId %>/members">👥 Members</a><% } %>
  <a class="navlink <%= page === 'console' ? 'active' : '' %>" href="/servers/<%= guildId %>/console">🖥️ Live Console</a>
  <a class="navlink <%= page === 'vip' ? 'active' : '' %>" href="/servers/<%= guildId %>/vip">💎 VIP</a>

  <% if (canSee('manage_moderation') || canSee('manage_config') || canSee('manage_automod') || canSee('manage_antiraid')) { %>
  <div class="nav-section">Moderation</div>
  <% if (canSee('manage_moderation')) { %><a class="navlink <%= page === 'moderation' ? 'active' : '' %>" href="/servers/<%= guildId %>/moderation">🔨 Moderation</a><% } %>
  <% if (canSee('manage_automod') || canSee('manage_config')) { %><a class="navlink <%= page === 'automod' ? 'active' : '' %>" href="/servers/<%= guildId %>/automod">🛡️ AutoMod</a><% } %>
  <% if (canSee('manage_antiraid') || canSee('manage_config')) { %><a class="navlink <%= page === 'antiraid' ? 'active' : '' %>" href="/servers/<%= guildId %>/antiraid">🚨 Anti-Raid &amp; Auto-Role</a><% } %>
  <% if (canSee('manage_config')) { %><a class="navlink <%= page === 'verify' ? 'active' : '' %>" href="/servers/<%= guildId %>/verify">✅ Verification</a><% } %>
  <% if (canSee('manage_moderation')) { %><a class="navlink <%= page === 'warnings' ? 'active' : '' %>" href="/servers/<%= guildId %>/warnings">⚠️ Warnings</a><% } %>
  <% if (canSee('manage_moderation')) { %><a class="navlink <%= page === 'notes' ? 'active' : '' %>" href="/servers/<%= guildId %>/notes">🗒️ Moderator Notes</a><% } %>
  <a class="navlink <%= page === 'modlog' ? 'active' : '' %>" href="/servers/<%= guildId %>/modlog">📜 Mod Log</a>
  <a class="navlink <%= page === 'auditlog' ? 'active' : '' %>" href="/servers/<%= guildId %>/auditlog">🕵️ Audit Log</a>
  <% } %>

  <div class="nav-section">Engagement</div>
  <% if (canSee('manage_config')) { %><a class="navlink <%= page === 'leveling' ? 'active' : '' %>" href="/servers/<%= guildId %>/leveling">⭐ Leveling</a><% } %>
  <% if (canSee('manage_config')) { %><a class="navlink <%= page === 'starboard' ? 'active' : '' %>" href="/servers/<%= guildId %>/starboard">🌟 Starboard</a><% } %>
  <% if (canSee('manage_tickets')) { %><a class="navlink <%= page === 'tickets' ? 'active' : '' %>" href="/servers/<%= guildId %>/tickets">🎫 Tickets</a><% } %>
  <% if (canSee('manage_giveaways')) { %><a class="navlink <%= page === 'giveaways' ? 'active' : '' %>" href="/servers/<%= guildId %>/giveaways">🎉 Giveaways</a><% } %>
  <% if (canSee('manage_suggestions')) { %><a class="navlink <%= page === 'suggestions' ? 'active' : '' %>" href="/servers/<%= guildId %>/suggestions">💡 Suggestions</a><% } %>
  <% if (canSee('manage_reactionroles')) { %><a class="navlink <%= page === 'reactionroles' ? 'active' : '' %>" href="/servers/<%= guildId %>/reactionroles">🎭 Reaction Roles</a><% } %>

  <% if (canSee('manage_config') || canSee('manage_embeds') || canSee('manage_customcommands')) { %>
  <div class="nav-section">Content</div>
  <% if (canSee('manage_config')) { %><a class="navlink <%= page === 'welcome' ? 'active' : '' %>" href="/servers/<%= guildId %>/welcome">👋 Welcome / Leave</a><% } %>
  <% if (canSee('manage_embeds')) { %><a class="navlink <%= page === 'embeds' ? 'active' : '' %>" href="/servers/<%= guildId %>/embeds">💬 Custom Embeds</a><% } %>
  <% if (canSee('manage_customcommands')) { %><a class="navlink <%= page === 'customcommands' ? 'active' : '' %>" href="/servers/<%= guildId %>/customcommands">⚡ Custom Commands</a><% } %>
  <% } %>

  <% if (canSee('manage_commands') || isServerManager) { %>
  <div class="nav-section">Access Control</div>
  <% if (canSee('manage_commands')) { %><a class="navlink <%= page === 'commands' ? 'active' : '' %>" href="/servers/<%= guildId %>/commands">🎛️ Command Toggles</a><% } %>
  <% if (isServerManager) { %><a class="navlink <%= page === 'teams' ? 'active' : '' %>" href="/servers/<%= guildId %>/teams">👑 Teams &amp; Permissions</a><% } %>
  <% } %>

  <% if (canSee('manage_config')) { %>
  <div class="nav-section">Server</div>
  <a class="navlink <%= page === 'backup' ? 'active' : '' %>" href="/servers/<%= guildId %>/backup">💾 Backup &amp; Restore</a>
  <% } %>

  <a class="back-link" href="/servers">← All servers</a>
  <a class="back-link" href="<%= config.discordSupportUrl %>" target="_blank" rel="noopener">💬 Support Discord</a>
</aside>
