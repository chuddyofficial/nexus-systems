<!doctype html>
<html lang="en">
<head><%- include('../partials/head', { title: 'Website Admin — Overview' }) %></head>
<body>
  <div class="app-shell">
    <%- include('../partials/adminSidebar', { page: 'overview' }) %>
    <main class="main" style="max-width:1100px;">
      <div class="page-header">
        <h1>⚙️ Website Admin</h1>
        <p>Site-wide controls for the whole bot, across every server it's in. Visible only to the configured owner account.</p>
      </div>

      <div class="grid grid-3" id="stat-tiles">
        <div class="stat-tile"><div class="stat-value" id="stat-guilds">—</div><div class="stat-label">Servers</div></div>
        <div class="stat-tile"><div class="stat-value" id="stat-members">—</div><div class="stat-label">Total Members</div></div>
        <div class="stat-tile"><div class="stat-value" id="stat-ping">—</div><div class="stat-label">Gateway Ping</div></div>
      </div>

      <div class="card">
        <h2>Largest Servers</h2>
        <table>
          <thead><tr><th>Server</th><th>Members</th><th></th></tr></thead>
          <tbody id="top-servers-body"></tbody>
        </table>
      </div>

      <div class="card">
        <h2>🔍 User Lookup</h2>
        <p class="card-desc">Search a Discord user ID for warnings, mod notes, and mod actions across every server the bot is in.</p>
        <div class="row">
          <div class="field" style="flex:1;"><input type="text" id="lookup-input" placeholder="Discord user ID" /></div>
          <button class="btn btn-primary" style="flex:0 0 auto;" id="lookup-btn">Search</button>
        </div>
        <div id="lookup-results" style="display:none;margin-top:16px;">
          <h3 style="font-size:13px;color:var(--text-muted);">Warnings</h3>
          <table><thead><tr><th>Server</th><th>Reason</th><th>Date</th></tr></thead><tbody id="lookup-warnings"></tbody></table>
          <h3 style="font-size:13px;color:var(--text-muted);margin-top:16px;">Mod Notes</h3>
          <table><thead><tr><th>Server</th><th>Note</th><th>Date</th></tr></thead><tbody id="lookup-notes"></tbody></table>
          <h3 style="font-size:13px;color:var(--text-muted);margin-top:16px;">Mod Actions</h3>
          <table><thead><tr><th>Server</th><th>Action</th><th>Date</th></tr></thead><tbody id="lookup-actions"></tbody></table>
        </div>
      </div>

      <div class="card">
        <h2>Quick Links</h2>
        <div class="cta" style="justify-content:flex-start;">
          <a class="btn btn-primary" href="/admin/servers">🌐 Manage All Servers</a>
          <a class="btn" href="/admin/broadcast">📢 Broadcast a Message</a>
          <a class="btn" href="/admin/system">🖥️ Bot Control</a>
        </div>
      </div>
    </main>
  </div>

  <div id="toast-root"></div>
  <script src="/js/common.js"></script>
  <script src="/js/admin-overview.js"></script>
</body>
</html>
