<!doctype html>
<html lang="en">
<head><%- include('../partials/head', { title: guild.name + ' — Suggestions' }) %></head>
<body>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>
    <main class="main">
      <div class="page-header">
        <h1>Suggestions</h1>
        <p>Members submit ideas with <span class="mono">/suggest</span>. Approve or deny them here.</p>
      </div>

      <div class="card">
        <h2>Suggestions Channel</h2>
        <div class="row">
          <div class="field"><label>Channel</label><select id="suggestions_channel"></select></div>
        </div>
        <button class="btn btn-primary" id="save-channel">Save</button>
      </div>

      <div class="card">
        <h2>All Suggestions</h2>
        <div id="sg-list"></div>
        <div id="sg-empty" class="empty-state" style="display:none;">No suggestions yet.</div>
      </div>
    </main>
  </div>

  <div id="toast-root"></div>
  <script src="/js/common.js"></script>
  <script>window.GUILD_ID = <%- JSON.stringify(guildId) %>;</script>
  <script src="/js/suggestions.js"></script>
</body>
</html>
