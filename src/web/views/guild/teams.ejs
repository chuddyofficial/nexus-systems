<!doctype html>
<html lang="en">
<head><%- include('../partials/head', { title: guild.name + ' — Teams & Permissions' }) %></head>
<body>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>
    <main class="main" style="max-width:1100px;">
      <div class="page-header">
        <h1>Teams &amp; Permissions</h1>
        <p>Create Teams (e.g. Admin, Moderator, Support) and grant them specific dashboard permissions — then add members by Discord ID or Discord role, without giving them full "Manage Server" access. Only Discord "Manage Server" holders can manage Teams.</p>
      </div>

      <div class="card">
        <h2>Create a Team</h2>
        <div class="row">
          <div class="field"><label>Name</label><input type="text" id="team-name" placeholder="e.g. Support Team" /></div>
          <div class="field"><label>Color</label><input type="color" id="team-color" value="#5865f2" style="height:42px;" /></div>
        </div>
        <button class="btn btn-primary" id="team-create">+ Create Team</button>
      </div>

      <div id="teams-list"></div>
    </main>
  </div>

  <div id="toast-root"></div>
  <script src="/js/common.js"></script>
  <script>window.GUILD_ID = <%- JSON.stringify(guildId) %>;</script>
  <script src="/js/teams.js"></script>
</body>
</html>
