<!doctype html>
<html lang="en">
<head><%- include('../partials/head', { title: guild.name + ' — Members' }) %></head>
<body>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>
    <main class="main" style="max-width:1300px;">
      <div class="page-header">
        <h1>Members</h1>
        <p>Search members and take quick moderation actions.</p>
      </div>

      <div class="card">
        <input type="text" id="search-input" placeholder="Search by name or ID..." />
      </div>

      <div class="card">
        <div id="members-list"></div>
        <div id="members-empty" class="empty-state" style="display:none;">No members found.</div>
      </div>
    </main>
  </div>

  <div id="toast-root"></div>
  <script src="/js/common.js"></script>
  <script>window.GUILD_ID = <%- JSON.stringify(guildId) %>;</script>
  <script src="/js/members.js"></script>
</body>
</html>
