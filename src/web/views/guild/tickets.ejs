<!doctype html>
<html lang="en">
<head><%- include('../partials/head', { title: guild.name + ' — Tickets' }) %></head>
<body>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>
    <main class="main" style="max-width:1100px;">
      <div class="page-header">
        <h1>Support Tickets</h1>
        <p>Create as many ticket panels ("sectors") as you need — each with its own embed, button, support role, ticket category, transcript log, and dropdown categories. Fully editable here, no code required.</p>
      </div>

      <div class="card">
        <h2>Create a Ticket Panel</h2>
        <div class="row">
          <div class="field"><label>Panel Name</label><input type="text" id="panel-name" placeholder="e.g. General Support" /></div>
        </div>
        <button class="btn btn-primary" id="panel-create">+ Create Panel</button>
      </div>

      <div id="panels-list"></div>

      <div class="card">
        <h2>Auto-Close</h2>
        <p class="card-desc">Applies to every panel. A ticket with no activity for this long will be closed automatically.</p>
        <div class="row">
          <div class="field"><label>Auto-close after inactivity (hours, 0 = off)</label><input type="number" id="auto_close_hours" min="0" max="720" /></div>
          <div class="field"><label>Default Transcript Channel (fallback if a panel has none set)</label><select id="default_transcript_channel"></select></div>
        </div>
        <button class="btn" id="save-ticket-settings">Save</button>
      </div>

      <div class="card">
        <h2>Open Tickets</h2>
        <table>
          <thead><tr><th>Channel</th><th>Opened By</th><th>Category</th><th>Claimed By</th><th>Opened</th><th></th></tr></thead>
          <tbody id="open-body"></tbody>
        </table>
        <div id="open-empty" class="empty-state" style="display:none;">No open tickets.</div>
      </div>

      <div class="card">
        <h2>Recent History</h2>
        <table>
          <thead><tr><th>Channel</th><th>User</th><th>Category</th><th>Status</th><th>Opened</th></tr></thead>
          <tbody id="history-body"></tbody>
        </table>
      </div>
    </main>
  </div>

  <div id="toast-root"></div>
  <script src="/js/common.js"></script>
  <script>window.GUILD_ID = <%- JSON.stringify(guildId) %>;</script>
  <script src="/js/tickets.js"></script>
</body>
</html>
