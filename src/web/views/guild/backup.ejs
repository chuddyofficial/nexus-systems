<!doctype html>
<html lang="en">
<head><%- include('../partials/head', { title: guild.name + ' — Backup & Restore' }) %></head>
<body>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>
    <main class="main">
      <div class="page-header">
        <h1>Backup &amp; Restore</h1>
        <p>Export the full bot configuration for this server as JSON, or restore from a previous export.</p>
      </div>

      <div class="card">
        <h2>Export</h2>
        <p class="card-desc">Downloads all logging, AutoMod, welcome/leave, leveling, starboard, ticket, and anti-raid settings as a JSON file.</p>
        <button class="btn btn-primary" id="export-btn">⬇️ Download Backup</button>
      </div>

      <div class="card">
        <h2>Restore</h2>
        <p class="card-desc">Upload a previously exported JSON file to overwrite this server's current settings.</p>
        <input type="file" id="restore-file" accept="application/json" />
        <button class="btn" id="restore-btn" style="margin-top:12px;">⬆️ Restore Settings</button>
      </div>
    </main>
  </div>

  <div id="toast-root"></div>
  <script src="/js/common.js"></script>
  <script>window.GUILD_ID = <%- JSON.stringify(guildId) %>;</script>
  <script src="/js/backup.js"></script>
</body>
</html>
