<!doctype html>
<html lang="en">
<head><%- include('../partials/head', { title: guild.name + ' — Mod Log' }) %></head>
<body>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>
    <main class="main">
      <div class="page-header">
        <h1>Moderation Log</h1>
        <p>Most recent 200 moderation actions in <strong><%= guild.name %></strong>.</p>
      </div>
      <div class="card">
        <table>
          <thead><tr><th>Action</th><th>User</th><th>Moderator</th><th>Reason</th><th>When</th></tr></thead>
          <tbody id="modlog-body"></tbody>
        </table>
        <div id="modlog-empty" class="empty-state" style="display:none;">No moderation actions yet.</div>
      </div>
    </main>
  </div>

  <div id="toast-root"></div>
  <script src="/js/common.js"></script>
  <script>window.GUILD_ID = <%- JSON.stringify(guildId) %>;</script>
  <script src="/js/modlog.js"></script>
</body>
</html>
