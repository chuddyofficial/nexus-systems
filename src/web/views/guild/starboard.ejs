<!doctype html>
<html lang="en">
<head><%- include('../partials/head', { title: guild.name + ' — Starboard' }) %></head>
<body>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>
    <main class="main">
      <div class="page-header">
        <h1>Starboard</h1>
        <p>Messages that get enough star reactions get reposted to a highlights channel.</p>
      </div>

      <div class="card">
        <div class="toggle-row">
          <div><div class="toggle-label">Enable Starboard</div></div>
          <label class="switch"><input type="checkbox" id="starboard_enabled" /><span class="slider"></span></label>
        </div>
        <div class="row" style="margin-top:14px;">
          <div class="field"><label>Starboard Channel</label><select id="starboard_channel"></select></div>
          <div class="field"><label>Emoji</label><input type="text" id="starboard_emoji" maxlength="4" /></div>
          <div class="field"><label>Threshold (stars)</label><input type="number" id="starboard_threshold" min="1" max="100" /></div>
        </div>
        <button class="btn btn-primary" id="save-btn">Save Starboard Settings</button>
      </div>
    </main>
  </div>

  <div id="toast-root"></div>
  <script src="/js/common.js"></script>
  <script>window.GUILD_ID = <%- JSON.stringify(guildId) %>;</script>
  <script src="/js/starboard.js"></script>
</body>
</html>
