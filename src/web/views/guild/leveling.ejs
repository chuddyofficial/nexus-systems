<!doctype html>
<html lang="en">
<head><%- include('../partials/head', { title: guild.name + ' — Leveling' }) %></head>
<body>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>
    <main class="main">
      <div class="page-header">
        <h1>Leveling</h1>
        <p>Members earn XP for chatting and level up over time. Use <span class="mono">/rank</span> in Discord to check progress.</p>
      </div>

      <div class="card">
        <div class="toggle-row">
          <div><div class="toggle-label">Enable Leveling</div><div class="toggle-desc">Members gain 15-25 XP per message (60s cooldown).</div></div>
          <label class="switch"><input type="checkbox" id="leveling_enabled" /><span class="slider"></span></label>
        </div>
        <div class="field" style="margin-top:14px;"><label>Level-up Announcement Channel</label><select id="leveling_announce_channel"></select></div>
        <div class="field"><label>Level-up Message</label><input type="text" id="leveling_announce_message" /><div class="field-hint">Placeholders: {user} {level} {server}</div></div>
        <div class="field"><label>XP Multiplier (%, 100 = normal) <span id="vip-multiplier-note" class="muted" style="display:none;">— VIP servers get an automatic extra 2x on top of this</span></label><input type="number" id="leveling_xp_multiplier" min="0" max="1000" step="25" /></div>
        <button class="btn btn-primary" id="save-btn">Save Leveling Settings</button>
      </div>

      <div class="card">
        <h2>No-XP Channels</h2>
        <p class="card-desc">Messages in these channels never earn XP (e.g. bot-commands, giveaway channels).</p>
        <div class="row">
          <select id="noxp-channel-select"></select>
          <button class="btn" id="add-noxp-channel" style="flex:0 0 auto;">Add</button>
        </div>
        <div class="tag-list" id="noxp-channels-list"></div>
      </div>

      <div class="card">
        <h2>Level-Up Role Rewards</h2>
        <p class="card-desc">Automatically grant a role when a member reaches a given level. Roles stack — a member keeps earlier rewards too.</p>
        <div class="row">
          <div class="field"><label>Level</label><input type="number" id="lr-level" min="1" placeholder="5" /></div>
          <div class="field"><label>Role</label><select id="lr-role"></select></div>
          <div style="flex:0 0 auto;display:flex;align-items:flex-end;"><button class="btn" id="lr-add">+ Add</button></div>
        </div>
        <table>
          <thead><tr><th>Level</th><th>Role</th><th></th></tr></thead>
          <tbody id="lr-body"></tbody>
        </table>
        <div id="lr-empty" class="empty-state" style="display:none;">No level roles configured.</div>
      </div>

      <div class="card">
        <h2>Leaderboard</h2>
        <table>
          <thead><tr><th>#</th><th>User</th><th>Level</th><th>XP</th><th></th></tr></thead>
          <tbody id="lb-body"></tbody>
        </table>
        <div id="lb-empty" class="empty-state" style="display:none;">No XP data yet.</div>
      </div>
    </main>
  </div>

  <div id="toast-root"></div>
  <script src="/js/common.js"></script>
  <script>window.GUILD_ID = <%- JSON.stringify(guildId) %>;</script>
  <script src="/js/leveling.js"></script>
</body>
</html>
